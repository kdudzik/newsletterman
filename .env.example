# OpenAI — used for gpt-4o-mini summarization
OPENAI_API_KEY=sk-...

# Google OAuth — Desktop app credentials from GCP project
# Gmail API must be enabled in that project
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//...

# Gmail label to treat as the reading list (default: "Read later")
GMAIL_READ_LATER_LABEL=Read later

# Subject substring to exclude from the list (optional — leave blank to show all)
NEWSLETTER_EXCLUDE_SUBJECT=

# Path to a markdown file describing your values and worldview (optional).
# When present, each newsletter gets relevance + challenge scores (0–10) via GPT.
# Defaults to personal_context.md in the project root if it exists.
PERSONAL_CONTEXT_FILE=personal_context.md

# Raindrop.io — articles from your Unsorted/Inbox collection (optional)
# Get your test token from https://app.raindrop.io/settings/integrations
RAINDROP_TEST_TOKEN=

# Wyborcza.pl Schowek (optional)
# Cookies are read automatically from Chrome — just be logged in to wyborcza.pl in Chrome.
WYBORCZA_SCHOWEK_URL=

# YouTube Watch Later (optional)
# Cookies are read automatically from Chrome — just be logged in to YouTube in Chrome.
# No cookie file needed.
YOUTUBE_ENABLED=

# Server port (default: 7431)
PORT=7431
